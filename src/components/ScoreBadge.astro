---
const { score, label, strength } = Astro.props;
const cls = score === null ? 'score-none' : score >= 80 ? 'score-high' : score >= 60 ? 'score-mid' : 'score-low';
---
<div class={`score-badge ${cls}`} aria-label={`Fairness Score ${score ?? 'not available'}, ${label}, data strength ${strength}`}>
  <strong>{score ?? '—'}</strong><span>{label}</span><small>{strength}</small>
</div>
