---
interface Props { lang?: 'en' | 'es'; }
const { lang = 'en' } = Astro.props as Props;
const es = lang === 'es';
---
<div class="notice warning" role="status">
  <strong>{es ? 'Vista previa con datos sintéticos.' : 'Fixture-only preview.'}</strong>
  {es
    ? ' Todos los nombres, registros, puntuaciones y tendencias de esta vista son sintéticos. No se publica ninguna conclusión sobre un juez o tribunal real.'
    : ' All names, records, scores, and trends in this view are synthetic. No conclusion about a real judge or court is being published.'}
</div>
