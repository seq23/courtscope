---
import ScoreBadge from './ScoreBadge.astro';
const { judge } = Astro.props;
---
<article class="card judge-card" data-court={judge.court} data-year={judge.nextElectionYear} data-strength={judge.dataStrength}>
  <div><p class="eyebrow">{judge.court} · {judge.division}</p><h3><a href={`/judges/${judge.slug}`}>{judge.shortName}</a></h3><p>{judge.caseCount.toLocaleString()} qualifying fixture cases · {judge.trend}</p><p><strong>Next election:</strong> {judge.nextElectionYear}</p></div>
  <ScoreBadge score={judge.score} label={judge.label} strength={judge.dataStrength} />
</article>
