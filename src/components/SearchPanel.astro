---
interface Props { lang?: 'en' | 'es'; citySlug?: string; }
const { lang = 'en', citySlug = 'memphis' } = Astro.props as Props;
const prefix = lang === 'es' ? '/es' : '';
const es = lang === 'es';
---
<form class="search-panel" action={`${prefix}/${citySlug}/cases`} method="get">
  <label for="q">{es ? 'Buscar por número público de caso' : 'Search by public case number'}</label>
  <div>
    <input id="q" name="q" type="search" autocomplete="off" placeholder={es ? 'Ejemplo: FX-2025-0001' : 'Example: FX-2025-0001'} />
    <button type="submit">{es ? 'Buscar caso' : 'Search cases'}</button>
  </div>
  <small>{es ? 'CourtScope no muestra nombres de acusados.' : 'CourtScope does not display defendant names.'}</small>
</form>
