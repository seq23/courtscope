---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompletenessChecklist from '../../components/CompletenessChecklist.astro';
import { visibleCities, publishedCities } from '../../lib/cities';
---
<BaseLayout lang="es" title="Datos por ciudad | CourtScope"><section class="hero compact-hero"><div class="shell"><p class="eyebrow">Traducción automática · Centro nacional de datos</p><h1>Datos por ciudad</h1><p class="lede">Cada ciudad tiene su propio estado, cobertura y archivos.</p></div></section><section class="section"><div class="shell"><div class="notice"><strong>{publishedCities.length} conjuntos de datos publicados.</strong> Una vista previa visible no es una publicación.</div><div class="grid grid-2">{visibleCities.map((city) => <article class="card city-card"><div><h2>{city.name}</h2><p>{city.published ? 'Publicada' : 'Vista previa; descargas bloqueadas'}</p></div><a class="button secondary" href={`/es/${city.slug}/data`}>Ver datos</a></article>)}</div></div></section><section class="section section-tint"><div class="shell"><h2>Los datos incompletos se rechazan</h2><CompletenessChecklist lang="es" /></div></section></BaseLayout>
