import BaseLayout from '../../layouts/BaseLayout.astro';
import CompletenessChecklist from '../../components/CompletenessChecklist.astro';
---
<BaseLayout lang="es" title="Agregar una ciudad | CourtScope"><section class="hero compact-hero"><div class="shell"><p class="eyebrow">Traducción automática · Guía de solicitud</p><h1>Lleve CourtScope a su ciudad</h1><p class="lede">Una ciudad publicable comienza con un conjunto de datos completo, autorizado y revisado por privacidad.</p></div></section><section class="section"><div class="shell"><h2>A quién contactar</h2><div class="grid grid-3 office-grid"><article class="card"><h3>Secretaría o archivo del tribunal</h3><p>Solicite la exportación de casos, resultados y sentencias.</p></article><article class="card"><h3>Administración o tecnología del tribunal</h3><p>Pregunte por identificadores, sistemas antiguos y límites de exportación.</p></article><article class="card"><h3>Oficina administrativa estatal</h3><p>Pregunte si existe una base de datos central.</p></article><article class="card"><h3>Oficial de registros públicos</h3><p>Use el portal oficial cuando la jurisdicción centraliza solicitudes.</p></article><article class="card"><h3>Fiscalía o correcciones</h3><p>Puede completar campos documentados que falten.</p></article><article class="card"><h3>Oficina electoral</h3><p>Úsela para verificar elecciones, no para datos de sentencia.</p></article></div><h2>Qué significa completo</h2><CompletenessChecklist lang="es" /><details class="request-accordion"><summary>Modelo breve de solicitud</summary><pre class="email-copy">Asunto: Solicitud de datos completos de sentencias penales\n\nSolicito una exportación electrónica de todos los casos penales resueltos en [tribunal] durante [fechas], con todos los tribunales y divisiones declarados. Incluya identificadores estables, juez, delito, antecedentes, declaración o juicio, resultado, fecha de sentencia, encarcelamiento, duración, raza, edad y género mantenidos en el sistema. Incluya un diccionario de datos, notas de cobertura, huecos conocidos y términos de reutilización.</pre></details></div></section></BaseLayout>
