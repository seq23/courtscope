---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompletenessChecklist from '../components/CompletenessChecklist.astro';
const emailOne = `Subject: Request for complete criminal sentencing data\n\nHello,\n\nI am requesting an electronic export of criminal case and sentencing records for [court or jurisdiction] covering [date range]. Please include all divisions and all disposed criminal cases in the declared scope.\n\nRequested fields include stable case and judge identifiers, judge name, court and division, offense classification, prior-record information, plea or trial status, disposition, sentence date, incarceration-to-serve outcome, sentence length, and the race, age band, and gender fields maintained in the source system.\n\nPlease also provide a data dictionary, coverage notes, known gaps, correction history, and the office’s reuse terms. A machine-readable CSV or JSON export is preferred.\n\nPlease tell me whether another office is the correct custodian for any part of this request.\n\nThank you,\n[Name]`;
const emailFollow = `Subject: Follow-up on criminal sentencing data request\n\nHello,\n\nI am following up on my request dated [date]. Could you confirm whether the office has all records needed to cover every declared court, division, and year in the request?\n\nPlease identify any missing years, excluded case types, retired systems, judge-name changes, amended sentences, or fields that cannot be exported. If another custodian holds part of the dataset, please provide that office’s general contact information.\n\nThank you,\n[Name]`;
---
<BaseLayout title="Add a City | CourtScope" description="Request complete criminal sentencing data and submit a privacy-safe city package to CourtScope.">
  <section class="hero compact-hero"><div class="shell"><p class="eyebrow">Records request and secure intake</p><h1>Bring CourtScope to your city</h1><p class="lede">Request the complete records, package them correctly, and upload the finished de-identified dataset for private CourtScope review.</p><div class="hero-actions"><a class="button" href="#submit-city-data">Upload city data</a><a class="button secondary" href="#request-records">Request records first</a></div></div></section>

  <section id="submit-city-data" class="section"><div class="shell upload-layout">
    <div><p class="eyebrow">Public submission</p><h2>Upload a complete city-data package</h2><p>This is the missing receiving lane. Your ZIP goes into <strong>private R2 quarantine</strong>, appears in the protected admin review queue, and does not enter GitHub or become public until an owner approves it.</p><div class="notice"><strong>Do not upload names or direct identifiers.</strong> The automated repository lane accepts only a complete, de-identified, machine-readable package. Email <a href="mailto:info@courtscope.org">info@courtscope.org</a> before sending raw records or files larger than 50 MB.</div><h3>Your ZIP must contain</h3><ol class="numbered-steps compact"><li><strong>manifest.json</strong><span>Use the CourtScope manifest and mark every completeness and privacy check true only when verified.</span></li><li><strong>One CSV or JSON dataset</strong><span>The filename must match the manifest.</span></li><li><strong>A data dictionary</strong><span>TXT, Markdown, CSV, JSON, or PDF; the filename must match the manifest.</span></li></ol><div class="actions"><a class="button secondary" href="/city-intake/manifest-template.json" download>Download manifest template</a><a class="button secondary" href="/city-intake/data-dictionary-template.csv" download>Download dictionary template</a></div></div>
    <form id="city-submission-form" class="card stacked-form upload-form" method="post" action="/api/city-submissions" enctype="multipart/form-data">
      <div class="form-section-title"><span>1</span><div><h3>City and coverage</h3><p>These values must match manifest.json.</p></div></div>
      <div class="form-grid"><label>City<input name="city_name" autocomplete="address-level2" required /></label><label>County or equivalent<input name="county" required /></label><label>State<input name="state" autocomplete="address-level1" required /></label><label>Country<input name="country" value="United States" required /></label><label>Coverage start<input name="coverage_start" type="date" required /></label><label>Coverage end<input name="coverage_end" type="date" required /></label></div>
      <div class="form-section-title"><span>2</span><div><h3>Source and contact</h3><p>Private admin-use information.</p></div></div>
      <div class="form-grid"><label>Official source agency<input name="source_agency" required /></label><label>Official source URL<input name="source_url" type="url" placeholder="https://..." required /></label><label>Your name<input name="contact_name" autocomplete="name" required /></label><label>Your email<input name="contact_email" type="email" autocomplete="email" required /></label><label>Organization<input name="organization" autocomplete="organization" /></label><label>Your role<input name="submitter_role" /></label></div>
      <div class="form-section-title"><span>3</span><div><h3>Complete ZIP package</h3><p>Maximum 50 MB.</p></div></div>
      <label class="file-drop">Choose ZIP file<input name="data_bundle" type="file" accept=".zip,application/zip" required /><small>One ZIP only. The server checks the manifest, declared files, date match, attestations, executable-file ban, and archive safety before storing it.</small></label>
      <div class="attestation-list"><label><input type="checkbox" name="authorized_source" required /> The package comes from an official or authorized source.</label><label><input type="checkbox" name="complete_scope" required /> The declared courts, divisions, years, and disposed cases are complete, with any gaps documented.</label><label><input type="checkbox" name="deidentified" required /> The ZIP contains no defendant names, addresses, Social Security numbers, phone numbers, email addresses, or other direct identifiers.</label><label><input type="checkbox" name="manifest_confirmed" required /> manifest.json and the data dictionary are included and accurately describe the package.</label></div>
      <label class="honeypot" aria-hidden="true">Company website<input name="company_website" tabindex="-1" autocomplete="off" /></label>
      <button type="submit">Upload for private review</button>
      <div id="city-submission-result" class="form-result" aria-live="polite"></div>
    </form>
  </div></section>

  <section id="request-records" class="section section-tint"><div class="shell"><div class="section-heading"><p class="eyebrow">Who to contact</p><h2>Start with the office that keeps the official records</h2><p>Office names differ across the country. Use official court and government directories to identify the records custodian.</p></div><div class="grid grid-3 office-grid"><article class="card"><h3>Court clerk or records office</h3><p class="office-role">Usually holds case, disposition, and sentence records.</p><p>Ask for the criminal case-management export, coverage notes, data dictionary, and correction history.</p></article><article class="card"><h3>Court administration or court IT</h3><p class="office-role">Often understands databases, judge identifiers, retired systems, and export limits.</p><p>Contact this office when the clerk can provide documents but not a complete machine-readable dataset.</p></article><article class="card"><h3>State court administrative office</h3><p class="office-role">May hold statewide or multi-county extracts.</p><p>Ask whether it maintains a central criminal case warehouse and whether local courts must approve release.</p></article><article class="card"><h3>County or city public-records officer</h3><p class="office-role">Routes requests under the local public-records process.</p><p>Use this contact when the court directs records requests through a central portal or legal office.</p></article><article class="card"><h3>Prosecutor, corrections, or jail data office</h3><p class="office-role">May hold fields missing from court exports.</p><p>These offices can sometimes fill documented gaps, but their data must be reconciled with the court source.</p></article><article class="card"><h3>Local elections office</h3><p class="office-role">Usually holds election and office-term facts, not sentencing data.</p><p>Use it later to verify election context. Election facts never change the Disparity Score.</p></article></div></div></section>
  <section class="section"><div class="shell"><div class="section-heading"><p class="eyebrow">Before you send</p><h2>Ask for a complete export</h2><p>Request the full declared court scope and require omitted years, divisions, judges, or sentence fields to be identified.</p></div><CompletenessChecklist /></div></section>
  <section class="section section-tint"><div class="shell"><div class="section-heading"><p class="eyebrow">Copy and adapt</p><h2>Sample email requests</h2></div><details class="request-accordion"><summary>Initial request for complete sentencing data</summary><pre class="email-copy">{emailOne}</pre></details><details class="request-accordion"><summary>Follow-up when coverage is unclear</summary><pre class="email-copy">{emailFollow}</pre></details><details class="request-accordion"><summary>What to say when an office offers PDFs only</summary><div class="accordion-body"><p>Thank the office, then ask whether the same records can be exported from the case-management system in CSV, JSON, spreadsheet, fixed-width, or database format. Explain that a machine-readable export is necessary to check completeness across all cases.</p></div></details><details class="request-accordion"><summary>What to say when different offices hold different fields</summary><div class="accordion-body"><p>Ask each custodian for a stable join key, field definitions, date coverage, and known exclusions. Do not assume two files can be combined merely because case numbers look similar.</p></div></details></div></section>
  <section class="section section-dark"><div class="shell"><div class="section-heading"><p class="eyebrow">After upload</p><h2>From private package to live city</h2></div><div class="pipeline"><article><h3>Private receipt</h3><p>The ZIP is stored in a non-public R2 intake folder and recorded in D1.</p></article><article><h3>Admin review</h3><p>An owner checks source authority, privacy, and whether the package is ready for repository processing.</p></article><article><h3>Automated validation</h3><p>The approved package enters the repo intake workflow and faces every completeness, identity, privacy, and statistical gate.</p></article><article><h3>Publish or reject</h3><p>Passing batches create the city dashboard and public downloads. Failing batches are rejected with reasons.</p></article><article><h3>Retention cleanup</h3><p>Processed or rejected private uploads move into controlled retention lanes for later admin cleanup.</p></article></div></div></section>
  <script is:inline>
    const form = document.querySelector('#city-submission-form');
    const output = document.querySelector('#city-submission-result');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = form.querySelector('button[type="submit"]');
      button.disabled = true;
      output.textContent = 'Uploading and checking the package…';
      output.className = 'form-result notice';
      try {
        const response = await fetch(form.action, { method: 'POST', body: new FormData(form) });
        const data = await response.json();
        output.textContent = data.message ? `${data.message} Receipt: ${data.submission_id || 'pending'}.` : data.error || `Status ${response.status}`;
        output.className = `form-result notice ${response.ok ? 'success' : 'error'}`;
        if (response.ok) form.reset();
      } catch {
        output.textContent = 'The upload could not reach CourtScope. No receipt was issued.';
        output.className = 'form-result notice error';
      } finally {
        button.disabled = false;
      }
    });
  </script>
</BaseLayout>
