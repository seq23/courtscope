---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FixtureBanner from '../../components/FixtureBanner.astro';
import JudgeCard from '../../components/JudgeCard.astro';
import SearchPanel from '../../components/SearchPanel.astro';
import MethodologySummary from '../../components/MethodologySummary.astro';
import { findCity, cityStatusLabel } from '../../lib/cities';
import { cityJudges } from '../../lib/city-data';

const city = findCity(Astro.params.city);
if (!city) return Astro.redirect('/cities');
const judges = cityJudges(city.slug);
const scored = judges.filter((judge) => judge.score !== null);
---
<BaseLayout title={`${city.name} Sentencing Dashboard | CourtScope`} description={`Explore measured racial gaps in sentencing outcomes for ${city.name}.`}>
  <section class="hero city-hero"><div class="shell city-header"><div><span class="city-kicker">{cityStatusLabel(city)}</span><p class="eyebrow">{city.county}, {city.state}</p><h1>{city.name} sentencing dashboard</h1><p class="lede">Explore judge-level patterns in incarceration and sentence length across qualifying cases.</p><div class="hero-actions"><a class="button" href={`/${city.slug}/judges`}>Browse judges</a><a class="button secondary" href={`/${city.slug}/compare`}>Compare judges</a></div></div><aside class="card"><h2>City status</h2><dl><dt>Data mode</dt><dd>{city.dataMode === 'fixture' ? 'Synthetic fixture preview' : 'Published official-data release'}</dd><dt>Judges shown</dt><dd>{judges.length}</dd><dt>Scored judges</dt><dd>{scored.length}</dd><dt>Downloads</dt><dd>{city.downloadsAvailable ? 'Available' : 'Locked until publication'}</dd></dl></aside></div></section>
  <section class="section"><div class="shell">{city.dataMode === 'fixture' && <FixtureBanner />}<div class="metric-band"><div><span>Judges shown</span><strong>{judges.length}</strong></div><div><span>Courts represented</span><strong>{city.courts.length}</strong></div><div><span>Publication state</span><strong>{city.published ? 'Live' : 'Preview'}</strong></div></div></div></section>
  <section class="section section-tint"><div class="shell"><div class="section-heading"><p class="eyebrow">Judge overview</p><h2>Disparity Score cards</h2><p>Open each accordion for a short explanation of the strongest measured signals.</p></div><div class="grid grid-2">{judges.map((judge) => <JudgeCard judge={judge} citySlug={city.slug} />)}</div></div></section>
  <section class="section"><div class="shell grid grid-2"><div><h2>Search a public case number</h2><p>Case pages show a limited public projection without defendant names.</p><SearchPanel citySlug={city.slug} /></div><div class="card"><h2>City data</h2><p>Review the city’s courts, source status, coverage window, completeness result, and download availability.</p><a class="button secondary" href={`/${city.slug}/data`}>View {city.name} data</a></div></div></section>
  <section class="section"><div class="shell"><MethodologySummary /></div></section>
</BaseLayout>
