---
import BaseLayout from '../../layouts/BaseLayout.astro';import SystemHealth from '../../components/SystemHealth.astro';
const operations=[['rerun_ingestion','Rerun ingestion','Reprocess the latest allowlisted source artifact.'],['recalculate_scores','Recalculate scores','Run the model and publication gates.'],['rebuild_exports','Rebuild exports','Regenerate CSV, JSON, and Parquet release files.'],['pause_automation','Pause automation','Stop scheduled mutations while keeping read access.'],['rollback_dataset','Rollback dataset','Restore the last verified dataset release.'],['emergency_stop','Emergency stop','Block every non-read-only admin action.']];
---
<BaseLayout title="Admin command center | CourtScope" noindex={true}><section class="section"><div class="shell"><div class="actions" style="justify-content:space-between"><div><p class="eyebrow">Owner control room</p><h1>Admin command center</h1></div><form method="post" action="/api/admin/logout"><button class="secondary" type="submit">Sign out</button></form></div><div class="notice"><strong>Provider-gated, not simulated.</strong> Actions call the secured admin endpoint. If Cloudflare or GitHub credentials are missing, the action returns a precise configuration error and makes no claim of success.</div><div class="actions"><a class="button" href="/admin/add-cities">Add court data or a city</a><a class="button secondary" href="/admin/corrections">Review corrections</a></div><SystemHealth/><h2>Operations</h2><div class="grid grid-3">{operations.map(([id,title,description])=><article class="card"><h3>{title}</h3><p>{description}</p><form class="admin-action" data-confirm={['recalculate_scores','pause_automation','rollback_dataset','emergency_stop'].includes(id)?'true':'false'}><input type="hidden" name="action" value={id}/><button class={id==='emergency_stop'?'danger':''} type="submit">{title}</button><div class="action-result" aria-live="polite"></div></form></article>)}</div></div></section><script is:inline>
document.querySelectorAll('.admin-action').forEach(form=>form.addEventListener('submit',async e=>{e.preventDefault();const action=new FormData(form).get('action');if(form.dataset.confirm==='true'&&!confirm(`Confirm ${action.replaceAll('_',' ')}?`))return;const out=form.querySelector('.action-result');out.textContent='Running…';try{const res=await fetch('/api/admin/actions',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({action,confirmed:true})});const data=await res.json();out.textContent=data.message||data.error||`Status ${res.status}`;out.className=`action-result notice ${res.ok?'success':'error'}`}catch(err){out.textContent='The request could not reach the admin service.';out.className='action-result notice error'}}));
</script></BaseLayout>
