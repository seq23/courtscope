---
import BaseLayout from '../../layouts/BaseLayout.astro';import contacts from '../../../data/cities/memphis_contact_guide.json';
const required=[['case_id','Stable case or indictment number','Required'],['court','Court and division','Required'],['sentencing_judge','Sentencing judge','Required'],['judge_dates','Judge assignment dates','Strongly preferred'],['charge_code','Charge code and description','Required'],['offense_severity','Offense class or severity','Required'],['filing_date','Filing date','Strongly preferred'],['disposition','Disposition and date','Required'],['plea_trial','Guilty plea versus trial','Required'],['sentence_date','Sentencing date','Required'],['incarceration','Incarceration, suspended time, and probation','Required'],['sentence_structure','Concurrent/consecutive structure','Strongly preferred'],['race','Race field and collection method','Required'],['age','Age or date of birth','Required'],['gender','Gender field and collection method','Strongly preferred'],['prior_record','Prior-record or offender-range information','Required'],['updated_at','Amendment/correction timestamps','Strongly preferred'],['dictionary','Source-system data dictionary','Required']];
---
<BaseLayout title="Add court data or a city | CourtScope" noindex={true}><section class="section"><div class="shell"><p class="eyebrow">Guided data onboarding</p><h1>Add court data or a new city</h1><p class="lede">This wizard creates the request package, tracks outreach, inspects uploaded data, maps court columns, and produces a readiness report. Nothing becomes public from this screen.</p><div class="notice warning"><strong>Memphis is the first jurisdiction example.</strong> Government contact information was verified on {contacts.verified_on}, but must be rechecked on the linked official page before use.</div><ol class="stepper" id="stepper">{['Jurisdiction','Records needed','Request package','Upload & map','Readiness'].map((x,i)=><li class={i===0?'active':''}>{i+1}. {x}</li>)}</ol><form id="city-wizard" novalidate>
<section class="wizard-step card" data-step="0"><h2>1. Choose the jurisdiction</h2><div class="form-grid"><label>City<input name="city" value="Memphis" required/></label><label>County<input name="county" value="Shelby County" required/></label><label>State<input name="state" value="Tennessee" required/></label><label>Court system<select name="court" id="court-select"><option value="shelby-criminal">Shelby County Criminal Court</option><option value="shelby-general-sessions-criminal">Shelby County General Sessions Criminal Division</option><option value="custom">Another court</option></select></label><label>Court type<select name="court_type"><option>Criminal Court</option><option>General Sessions Criminal Court</option><option>Other criminal trial court</option></select></label><label>Data status<select name="acquisition_status"><option>Not contacted</option><option>Request drafted</option><option>Request sent</option><option>Response received</option><option>Files received</option></select></label></div><div id="contact-card" class="notice"></div></section>
<section class="wizard-step card" data-step="1" hidden><h2>2. Confirm the records you need</h2><p>Mark what the court can provide. CourtScope will not treat an unavailable field as present.</p><div class="grid grid-2">{required.map(([id,label,level])=><label class="card field-status"><span>{label}<small class="help">{level}</small></span><select name={`field_${id}`} data-field={id} data-level={level}><option value="unknown">Unknown</option><option value="available">Available</option><option value="missing">Missing / unavailable</option><option value="clarify">Needs clarification</option></select></label>)}</div></section>
<section class="wizard-step card" data-step="2" hidden><h2>3. Generate and track the records request</h2><div class="form-grid"><label>Start year<input name="start_year" type="number" value="2018" min="1900" max="2100"/></label><label>End year<input name="end_year" type="number" value="2025" min="1900" max="2100"/></label><label>Preferred format<select name="preferred_format"><option>CSV or database export</option><option>JSON</option><option>XLSX</option><option>PDF only if structured data is unavailable</option></select></label><label>Date contacted<input name="date_contacted" type="date"/></label><label>Person contacted<input name="person_contacted"/></label><label>Request number<input name="request_number"/></label><label>Expected delivery date<input name="expected_delivery" type="date"/></label><label>Estimated fee<input name="estimated_fee" inputmode="decimal"/></label></div><label>Call or email notes<textarea name="communication_notes"></textarea></label><div class="actions"><button type="button" id="download-request">Download request package</button><button type="button" class="secondary" id="copy-email">Copy ready-to-send email</button></div><pre id="request-preview" class="receipt"></pre></section>
<section class="wizard-step card" data-step="3" hidden><h2>4. Upload and map court files</h2><label>Official court files<input id="court-files" name="files" type="file" multiple accept=".csv,.json,.xlsx,.xls,.pdf,.zip,.txt"/><span class="help">CSV, JSON, and XLSX receive automatic field detection. PDF and ZIP are preserved and classified; include a structured extract or data dictionary for reliable mapping.</span></label><div id="file-list" class="grid grid-2" style="margin-top:1rem"></div><h3>Detected field mapping</h3><div id="mapping-list"><p class="help">Upload a structured file to detect columns.</p></div></section>
<section class="wizard-step card" data-step="4" hidden><h2>5. Readiness report</h2><div id="readiness-summary"></div><h3>Coverage</h3><div id="coverage-bars" class="grid grid-2"></div><h3>Dry-run result</h3><pre id="dry-run" class="receipt">No dry run has been calculated yet.</pre><div class="actions"><button type="button" id="download-project">Download onboarding project</button><button type="button" class="secondary" id="save-project">Save and resume later</button></div></section>
<div class="actions" style="margin-top:1rem"><button type="button" class="secondary" id="back" disabled>Back</button><button type="button" id="next">Next step</button></div></form></div></section>
<script is:inline id="contacts-data" type="application/json" set:html={JSON.stringify(contacts)}></script><script is:inline id="required-data" type="application/json" set:html={JSON.stringify(required)}></script><script>import '../../scripts/cityWizard.ts';</script></BaseLayout>
