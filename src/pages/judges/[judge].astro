---
import BaseLayout from '../../layouts/BaseLayout.astro'; import FixtureBanner from '../../components/FixtureBanner.astro'; import ScoreBadge from '../../components/ScoreBadge.astro'; import { fixtureJudges, fixtureCases } from '../../lib/fixtures';
const judge=fixtureJudges.find(j=>j.slug===Astro.params.judge); if(!judge)return Astro.redirect('/judges?notfound=1'); const records=fixtureCases.filter(c=>c.judgeSlug===judge.slug);
---
<BaseLayout title={`${judge.shortName} | CourtScope`}><section class="section"><div class="shell"><FixtureBanner/><p class="eyebrow">{judge.court} · {judge.division}</p><div class="grid grid-2"><div><h1>{judge.shortName}</h1><p><strong>Next election:</strong> {judge.nextElectionYear}</p><p><strong>Trend:</strong> {judge.trend}</p><p>This fixture score summarizes adjusted aggregate disparity under a nonvalidated test methodology.</p></div><ScoreBadge score={judge.score} label={judge.label} strength={judge.dataStrength}/></div><details open><summary>Why this score?</summary><p>{judge.caseCount} synthetic qualifying cases were assigned to this preview. The production system will disclose comparison groups, model variables, uncertainty, exclusions, and methodology version here.</p>{judge.confidenceInterval&&<p><strong>Fixture confidence interval:</strong> {judge.confidenceInterval[0]}–{judge.confidenceInterval[1]}</p>}</details><h2>Election & background</h2><div class="card"><p>Professional background and election history require verified official sources and are intentionally absent from the fixture build.</p></div><h2>Cases used in this fixture</h2><div class="table-wrap"><table><thead><tr><th>Case</th><th>Disposition</th><th>Sentence</th><th>Model use</th></tr></thead><tbody>{records.length?records.map(c=><tr><td><a href={`/cases/${c.publicCaseNumber}`}>{c.publicCaseNumber}</a></td><td>{c.disposition}</td><td>{c.sentenceType}</td><td>{c.includedInModel?'Included':'Excluded'}</td></tr>):<tr><td colspan="4">No fixture cases assigned.</td></tr>}</tbody></table></div></div></section></BaseLayout>
