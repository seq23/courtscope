---
import BaseLayout from '../layouts/BaseLayout.astro'; import FixtureBanner from '../components/FixtureBanner.astro'; import SearchPanel from '../components/SearchPanel.astro'; import FilterBar from '../components/FilterBar.astro'; import JudgeCard from '../components/JudgeCard.astro'; import SystemHealth from '../components/SystemHealth.astro'; import { fixtureJudges } from '../lib/fixtures';
---
<BaseLayout title="CourtScope | See the patterns behind court outcomes"><section class="hero"><div class="shell"><p class="eyebrow">Shelby County, Tennessee</p><h1>See the patterns behind court outcomes.</h1><p class="lede">CourtScope is an open-source civic data project designed to help the public examine adjusted racial disparities in aggregate sentencing patterns—without declaring any individual case fair or unfair.</p><div class="notice"><strong>How to read this:</strong> A higher Fairness Score means lower measured disparity after controlling for supported case differences. It does not prove perfect fairness or intent.</div><SearchPanel /></div></section><section class="section"><div class="shell"><FixtureBanner/><div class="grid grid-2"><div><p class="eyebrow">Judges by Fairness Score</p><h2>Explore the fixture dashboard</h2><p>Scores publish only when sample size, subgroup coverage, source quality, uncertainty, and model stability pass hard gates.</p></div><SystemHealth/></div><FilterBar/><div class="grid grid-2">{fixtureJudges.sort((a,b)=>(a.score??999)-(b.score??999)).map(j=><JudgeCard judge={j}/>)}</div></div></section></BaseLayout>
