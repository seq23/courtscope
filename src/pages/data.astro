---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompletenessChecklist from '../components/CompletenessChecklist.astro';
import { visibleCities, publishedCities, cityStatusLabel } from '../lib/cities';
---
<BaseLayout title="CourtScope Data | City Datasets and Publication Rules" description="Choose a city dataset, review CourtScope completeness rules, and download only published privacy-safe releases.">
  <section class="hero compact-hero"><div class="shell"><p class="eyebrow">National data hub</p><h1>Data by city</h1><p class="lede">Each jurisdiction has its own source offices, court coverage, date window, release status, and downloadable files.</p></div></section>
  <section class="section"><div class="shell"><div class="notice"><strong>{publishedCities.length} published city dataset{publishedCities.length === 1 ? '' : 's'}.</strong> A visible preview is not the same as a published release.</div><div class="grid grid-2">{visibleCities.map((city) => <article class="card city-card"><div><span class="city-status">{cityStatusLabel(city)}</span><h2>{city.name}, {city.state}</h2><p>{city.notice}</p><p><strong>Downloads:</strong> {city.downloadsAvailable ? 'Available' : 'Locked'}</p></div><a class="button secondary" href={`/${city.slug}/data`}>View city data</a></article>)}</div></div></section>
  <section class="section section-tint"><div class="shell"><div class="section-heading"><p class="eyebrow">Publication gate</p><h2>Incomplete datasets are rejected</h2><p>CourtScope does not publish a partial dataset and call it representative. A batch must satisfy the full checklist and statistical minimums.</p></div><CompletenessChecklist /><div class="pipeline"><article><h3>Receive</h3><p>A complete, de-identified package enters the city intake folder with a manifest and data dictionary.</p></article><article><h3>Validate</h3><p>Schema, coverage, identity, provenance, privacy, and model publication gates are checked.</p></article><article><h3>Publish or reject</h3><p>Passing data creates a city release and downloads. Failing data moves to the rejection lane with a receipt.</p></article><article><h3>Retain and clean</h3><p>Processed intake packages move to a time-limited retention folder and appear in the admin cleanup queue.</p></article></div></div></section>
</BaseLayout>
